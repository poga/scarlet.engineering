<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - scarlet.engineering</title>
    <meta name="description" content="{{ description or 'scarlet.engineering blog' }}">

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">

    <!-- RSS Feed -->
    <link rel="alternate" type="application/atom+xml" title="Scarlet Engineering - Devlog" href="/blog/feed.xml">

    <!-- Open Graph -->
    <meta property="og:type" content="{{ ogType or 'website' }}">
    <meta property="og:url" content="https://scarlet.engineering{{ page.url }}">
    <meta property="og:title" content="{{ title }} - scarlet.engineering">
    <meta property="og:description" content="{{ description or 'scarlet.engineering blog' }}">
    <meta property="og:image" content="{{ image or 'https://scarlet.engineering/logo-v2.png' }}">

    <!-- Fonts (non-render-blocking) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@300;400;500;600;700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@300;400;500;600;700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet"></noscript>

    <style>
        :root {
            --color-alizarin: #7B1818;
            --color-claret: #6E2233;
            --color-madder: #A04040;
            --color-oxblood: #4A0000;
            --color-ink: #1A1A1A;
            --color-soot: #3D3D3D;
            --color-fog: #9A9A8E;
            --color-parchment: #E8E0D0;
            --color-gaslight: #D4A857;
            --color-verdigris: #4A766E;
            --font-heading: 'Roboto Slab', 'Rockwell', serif;
            --font-body: 'Lora', 'Georgia', serif;
            --font-mono: 'JetBrains Mono', 'Consolas', monospace;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        /* Guarantee nothing ever forces sideways scroll */
        html, body { overflow-x: hidden; }

        body {
            background-color: var(--color-ink);
            font-family: var(--font-body);
            font-size: 18px;
            line-height: 1.8;
            color: var(--color-parchment);
            overflow-wrap: break-word;
        }

        .blog-container {
            max-width: 720px;
            margin: 0 auto;
            padding: 60px 24px;
        }

        .blog-nav {
            margin-bottom: 48px;
        }

        .blog-nav a {
            color: var(--color-gaslight);
            text-decoration: none;
            font-family: var(--font-body);
            font-size: 1rem;
            transition: color 0.2s ease;
        }

        .blog-nav a:hover {
            color: var(--color-parchment);
        }

        h1, h2, h3, h4 {
            font-family: var(--font-heading);
            font-weight: 600;
            color: var(--color-parchment);
            line-height: 1.3;
        }

        h1 { font-size: 2rem; font-weight: 700; margin-bottom: 16px; }

        /* Section headers carry the gaslight accent — structure you can scan */
        h2 {
            font-size: 1.6rem;
            margin-top: 56px;
            margin-bottom: 16px;
            color: var(--color-gaslight);
            letter-spacing: 0.01em;
        }

        h3 {
            font-size: 1.25rem;
            margin-top: 32px;
            margin-bottom: 12px;
            color: var(--color-gaslight);
        }

        /* Bold reads as gold emphasis against parchment body */
        strong, b {
            color: var(--color-gaslight);
            font-weight: 700;
        }

        .blog-eyebrow {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--color-fog);
            margin-bottom: 32px;
        }

        .blog-list h2 {
            font-size: 1.5rem;
            font-weight: 500;
            margin-top: 0;
            margin-bottom: 8px;
        }

        a { color: var(--color-gaslight); transition: color 0.2s ease; }
        a:hover { color: var(--color-parchment); }

        p { margin-bottom: 1.2em; }

        ul, ol {
            margin-bottom: 1.2em;
            padding-left: 1.5em;
        }

        li { margin-bottom: 0.4em; }

        blockquote {
            border-left: 3px solid var(--color-alizarin);
            padding-left: 20px;
            margin: 1.5em 0;
            color: var(--color-fog);
            font-style: italic;
        }

        code {
            font-family: var(--font-mono);
            font-size: 0.85em;
            background: var(--color-soot);
            padding: 2px 6px;
            border-radius: 2px;
        }

        pre {
            background: var(--color-soot);
            padding: 16px 20px;
            border-radius: 2px;
            overflow-x: auto;
            margin-bottom: 1.5em;
            border: 1px solid #4A4A4A;
        }

        .mermaid {
            margin-bottom: 1.5em;
            overflow-x: auto;
            cursor: zoom-in;
        }

        .mermaid svg { max-width: 100%; height: auto; }

        .mermaid-overlay {
            position: fixed;
            inset: 0;
            z-index: 100;
            background: rgba(26, 26, 26, 0.96);
            display: flex;
            overflow: auto;
            padding: 32px;
            cursor: zoom-out;
        }

        /* margin:auto centers small diagrams and lets big ones scroll */
        .mermaid-overlay svg {
            flex-shrink: 0;
            margin: auto;
        }

        pre code {
            background: none;
            padding: 0;
            font-size: 0.85em;
            line-height: 1.6;
        }

        /* Prism syntax highlighting — matched to blog palette */
        .token.comment,
        .token.prolog,
        .token.doctype,
        .token.cdata { color: var(--color-fog); font-style: italic; }

        .token.punctuation { color: #B0A890; }

        .token.property,
        .token.tag,
        .token.boolean,
        .token.number,
        .token.constant,
        .token.symbol { color: #D4A857; }

        .token.selector,
        .token.attr-name,
        .token.string,
        .token.char,
        .token.builtin { color: #A8B88A; }

        .token.operator,
        .token.entity,
        .token.url,
        .language-css .token.string,
        .style .token.string { color: #C8A87A; }

        .token.atrule,
        .token.attr-value,
        .token.keyword { color: #C07878; }

        .token.function,
        .token.class-name { color: #D4A857; }

        .token.regex,
        .token.important,
        .token.variable { color: #C8A87A; }

        .token.important,
        .token.bold { font-weight: bold; }

        .token.italic { font-style: italic; }

        img {
            max-width: 100%;
            height: auto;
            border-radius: 2px;
            margin: 1.5em 0;
        }

        figure { margin: 1.5em 0; }
        figure img { margin: 0; }
        figcaption {
            text-align: center;
            font-size: 0.85em;
            color: var(--color-fog);
            margin-top: 0.6em;
        }

        /* Fixed-width embeds must stay inside the column */
        iframe, video, embed, object {
            max-width: 100%;
            margin: 1.5em 0;
        }

        /* Keep 16:9 video embeds responsive instead of fixed pixels */
        iframe[src*="youtube"] {
            width: 100%;
            height: auto;
            aspect-ratio: 16 / 9;
        }

        hr {
            border: none;
            border-top: 1px solid var(--color-soot);
            margin: 2em 0;
        }

        @media (max-width: 480px) {
            body { font-size: 16px; }
            .blog-container { padding: 32px 16px; }
            h1 { font-size: 1.5rem; }
            h2 { font-size: 1.25rem; }
            .blog-eyebrow { font-size: 0.7rem; }
            .blog-list h2 { font-size: 1.25rem; }
        }

        .post-subscribe { margin-top: 24px; }

        .post-subscribe hr { margin: 0 0 32px; }

        .post-subscribe-title {
            margin-top: 0;
            margin-bottom: 20px;
            font-size: 1.25rem;
        }

        .post-subscribe-form input[type="email"] {
            width: 100%;
            padding: 14px 16px;
            font-family: var(--font-body);
            font-size: 1rem;
            color: var(--color-parchment);
            background: var(--color-soot);
            border: 1px solid var(--color-fog);
            border-radius: 2px;
            outline: none;
            transition: border-color 0.2s;
        }

        .post-subscribe-form input[type="email"]:focus {
            border-color: var(--color-alizarin);
        }

        .post-subscribe-form input[type="submit"] {
            width: 100%;
            padding: 14px 24px;
            margin-top: 12px;
            font-family: var(--font-body);
            font-size: 1rem;
            font-weight: 600;
            color: var(--color-parchment);
            background: var(--color-alizarin);
            border: none;
            border-radius: 2px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .post-subscribe-form input[type="submit"]:hover {
            background: var(--color-madder);
        }

        @supports (-webkit-touch-callout: none) {
            .post-subscribe-form input[type="email"] { font-size: 16px; }
        }
    </style>
<!-- Privacy-friendly analytics by Plausible -->
<script async src="https://plausible.io/js/pa-vpVWCgjj_p7nIAv5omja9.js"></script>
<script>
  window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
  plausible.init()
</script>

    <script defer data-domain="scarlet.engineering" src="https://dev.scarlet.engineering/js/script.js"></script>
</head>
<body>
    <div class="blog-container">
        {{ content | safe }}
    </div>
    <script type="module">
      // Render ```mermaid fences as diagrams; loads mermaid only when needed
      const blocks = document.querySelectorAll('pre > code.language-mermaid');
      if (blocks.length) {
        const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');
        mermaid.initialize({ startOnLoad: false, theme: 'dark' });
        for (const code of blocks) {
          const holder = document.createElement('div');
          holder.className = 'mermaid';
          holder.textContent = code.textContent;
          code.closest('pre').replaceWith(holder);
        }
        await mermaid.run();

        // Click a diagram to view it full size; click again or Esc to close
        const openOverlay = (svg) => {
          const overlay = document.createElement('div');
          overlay.className = 'mermaid-overlay';
          const clone = svg.cloneNode(true);
          const vb = svg.viewBox.baseVal;
          const fit = Math.min(
            (window.innerWidth - 64) / vb.width,
            (window.innerHeight - 64) / vb.height
          );
          clone.style.maxWidth = 'none';
          clone.style.width = vb.width * Math.max(fit, 1) + 'px';
          clone.style.height = 'auto';
          overlay.appendChild(clone);
          const close = () => {
            overlay.remove();
            document.removeEventListener('keydown', onKey);
          };
          const onKey = (e) => { if (e.key === 'Escape') close(); };
          overlay.addEventListener('click', close);
          document.addEventListener('keydown', onKey);
          document.body.appendChild(overlay);
        };
        for (const holder of document.querySelectorAll('div.mermaid')) {
          const svg = holder.querySelector('svg');
          if (svg) holder.addEventListener('click', () => openOverlay(svg));
        }
      }
    </script>
</body>
</html>
