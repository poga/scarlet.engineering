---
layout: blog-base.njk
ogType: article
---
<nav class="blog-nav">
    <a href="/blog/">&larr; Back to blog</a>
</nav>
<article>
    <header>
        <h1>{{ title }}</h1>
        <time style="color: var(--color-fog); font-size: 0.9rem;">{{ date | dateDisplay }}</time>
    </header>
    {% set parts = collections.series[series] %}
    {% if parts %}
    <nav class="post-series" aria-label="{{ series }} series">
        <p class="post-series-label">Part {{ seriesPart }} of the series <strong>{{ series }}</strong></p>
        <ul class="post-series-list">
            {% for part in parts %}
            <li class="post-series-item">
                <span class="post-series-num">Part {{ part.data.seriesPart }}</span>
                {% if part.url == page.url %}
                <span class="post-series-current" aria-current="page">{{ part.data.seriesTitle or part.data.title }} <em>(you are here)</em></span>
                {% else %}
                <a href="{{ part.url }}">{{ part.data.seriesTitle or part.data.title }}</a>
                {% endif %}
            </li>
            {% endfor %}
        </ul>
    </nav>
    {% endif %}
    <div style="margin-top: 32px;">
        {{ content | safe }}
    </div>
</article>
<aside class="post-subscribe">
    <hr>
    <h3 class="post-subscribe-title">Enjoyed this? Get the next devlog in your inbox.</h3>
    <form
        action="https://buttondown.com/api/emails/embed-subscribe/scarlet.engineering"
        method="post"
        class="post-subscribe-form"
    >
        <input type="email" name="email" placeholder="you@example.com" />
        <input type="submit" value="Subscribe" />
    </form>
</aside>
